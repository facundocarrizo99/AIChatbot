# ──────────────────────────────────────────────────────────
# AIChatbot — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────

# ── WhatsApp Cloud API ────────────────────────────────────
# Get these from Meta App Dashboard > API Setup
# https://business.facebook.com/settings/system-users
ACCESS_TOKEN=""
APP_ID=""
APP_SECRET=""
RECIPIENT_WAID=""           # Your WhatsApp number with country code (e.g., +5491112345678)
VERSION="v18.0"
PHONE_NUMBER_ID=""
VERIFY_TOKEN=""

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_ASSISTANT_ID_ORIGINAL=""
OPENAI_ASSISTANT_ID_FACTURAS=""
OPENAI_ASSISTANT_ID_REGISTRAR=""
OPENAI_ASSISTANT_ID_GENERAL=""

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=""                # e.g., mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=""
DB_NAME_TEST=""

# ── ARCA / AFIP Configuration ────────────────────────────
ARCA_CUIT=""
ARCA_URL=""
AFIP_ENVIRONMENT="testing"  # "testing" or "production"
AFIP_CERT_FILE="/path/to/your/certificate.crt"
AFIP_PRIVATE_KEY_FILE="/path/to/your/private.key"
AFIP_CACHE_DIR="./afip_cache"
AFIP_CUIT=""
